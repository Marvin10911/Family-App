# Firebase Client Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin (Server-Side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# OpenAI
OPENAI_API_KEY=

# OpenWeatherMap (kostenlos bei openweathermap.org)
OPENWEATHER_API_KEY=

# Cron Job Security (beliebiger langer zufälliger String)
CRON_SECRET=

# App URL (für Verifizierungs-Links in E-Mails)
NEXT_PUBLIC_APP_URL=https://deine-app.vercel.app

# ── E-Mail-Versand (eine Option reicht) ─────────────────────────────────────
# Option A: Brevo (empfohlen – kostenlos, kein Domain nötig, HTTP-basiert)
#   1. Konto auf brevo.com erstellen (kostenlos, 300 Mails/Tag)
#   2. API-Key: Settings → API Keys
#   3. Absender verifizieren: Senders & IP → Senders → E-Mail-Adresse bestätigen
BREVO_API_KEY=
BREVO_FROM_EMAIL=familyapp.noreply@gmail.com

# Option B: Resend (erfordert verifizierte Domain auf resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Family App <noreply@deine-domain.de>

# Option C: Gmail SMTP (funktioniert ggf. nicht auf Vercel wegen Port-Sperrung)
EMAIL_USER=familyapp.noreply@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Ohne alle Optionen: Firebase-Standard-E-Mails als Fallback
