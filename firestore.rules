rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return request.auth.uid == userId;
    }

    function userFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    function isInFamily(familyId) {
      return userFamilyId() == familyId;
    }

    function isFamilyAdmin(familyId) {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return userFamilyId() == familyId && (role == 'owner' || role == 'admin');
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) ||
                     (isSignedIn() && resource.data.familyId != null &&
                      isFamilyAdmin(resource.data.familyId));
      allow delete: if isSelf(userId);
    }

    // Families
    match /families/{familyId} {
      allow read: if isSignedIn() && (
        resource == null || request.auth.uid in resource.data.members
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.members
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }

    // Shopping items
    match /shoppingItems/{itemId} {
      allow read: if isSignedIn() && isInFamily(resource.data.familyId);
      allow create: if isSignedIn() && isInFamily(request.resource.data.familyId);
      allow update, delete: if isSignedIn() && isInFamily(resource.data.familyId);
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && isInFamily(resource.data.familyId);
      allow create: if isSignedIn() && isInFamily(request.resource.data.familyId);
      allow update, delete: if isSignedIn() && isInFamily(resource.data.familyId);
    }

    // Meal plans
    match /mealPlans/{planId} {
      allow read: if isSignedIn() && isInFamily(resource.data.familyId);
      allow create: if isSignedIn() && isInFamily(request.resource.data.familyId);
      allow update, delete: if isSignedIn() && isInFamily(resource.data.familyId);
    }

    // Calendar events
    match /calendarEvents/{eventId} {
      allow read: if isSignedIn() && isInFamily(resource.data.familyId);
      allow create: if isSignedIn() && isInFamily(request.resource.data.familyId);
      allow update, delete: if isSignedIn() && isInFamily(resource.data.familyId);
    }

    // Waste entries
    match /wasteEntries/{entryId} {
      allow read: if isSignedIn() && isInFamily(resource.data.familyId);
      allow create: if isSignedIn() && isInFamily(request.resource.data.familyId);
      allow update, delete: if isSignedIn() && isInFamily(resource.data.familyId);
    }
  }
}
