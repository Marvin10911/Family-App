rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from a signed-in user?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: get the caller's familyId from their profile
    function callerFamilyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId;
    }

    // Helper: is the caller in the given family?
    function inFamily(familyId) {
      return isSignedIn() && callerFamilyId() == familyId;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read any user profile (needed to show family members)
      allow read: if isSignedIn();

      // Only the user themselves can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;

      // User can update their own doc; family/role changes go through Admin SDK (API routes)
      allow update: if isSignedIn() && request.auth.uid == userId;

      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ── Families ───────────────────────────────────────────────────────────
    match /families/{familyId} {
      // Members can read their family
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;

      // Listing families is needed for invite-code lookup (done via Admin SDK API route)
      // Direct client create/update/delete is blocked — use API routes instead
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Family data collections ────────────────────────────────────────────
    // Shopping, Tasks, Meals, Calendar, Waste — all follow the same pattern:
    // only members of the same family can read/write

    match /shoppingItems/{id} {
      allow read, write: if inFamily(resource.data.familyId);
      allow create: if isSignedIn() && callerFamilyId() == request.resource.data.familyId;
    }

    match /tasks/{id} {
      allow read, write: if inFamily(resource.data.familyId);
      allow create: if isSignedIn() && callerFamilyId() == request.resource.data.familyId;
    }

    match /mealPlans/{id} {
      allow read, write: if inFamily(resource.data.familyId);
      allow create: if isSignedIn() && callerFamilyId() == request.resource.data.familyId;
    }

    match /calendarEvents/{id} {
      allow read, write: if inFamily(resource.data.familyId);
      allow create: if isSignedIn() && callerFamilyId() == request.resource.data.familyId;
    }

    match /wasteEntries/{id} {
      allow read, write: if inFamily(resource.data.familyId);
      allow create: if isSignedIn() && callerFamilyId() == request.resource.data.familyId;
    }
  }
}
